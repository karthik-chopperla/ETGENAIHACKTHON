# Industrial Knowledge Intelligence System - Environment Variables
# Copy this file to .env and fill in your actual values

# ============= REQUIRED =============

# OpenAI API Key (for embeddings in RAG system)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Anthropic API Key (for Claude AI entity extraction and reasoning)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ============= DATABASE =============

# Database URL for storing documents and metadata
# For local development (SQLite):
DATABASE_URL=sqlite:///./ikis.db

# For production (PostgreSQL on Render):
# DATABASE_URL=postgresql://user:password@render-postgres-url.com:5432/ikis_db

# For production (PostgreSQL on Railway):
# DATABASE_URL=postgresql://postgres:password@rail-url.railway.app:5432/railway

# ============= NEO4J GRAPH DATABASE (OPTIONAL) =============

# Neo4j Connection URI
# Free tier: Get from https://neo4j.com/cloud/aura/
# NEO4J_URI=bolt://your-neo4j-url.com:7687
NEO4J_URI=bolt://localhost:7687

# Neo4j Username
NEO4J_USER=neo4j

# Neo4j Password
NEO4J_PASSWORD=password

# ============= FRONTEND CONFIGURATION =============

# Backend API URL (used by React frontend)
# For local development:
# REACT_APP_BACKEND_URL=http://localhost:8000

# For production (update with your Render backend URL):
# REACT_APP_BACKEND_URL=https://ikis-backend.onrender.com

# ============= OPTIONAL: API CONFIGURATION =============

# Port for local development (default: 8000)
# PORT=8000

# Environment type
# NODE_ENV=production
